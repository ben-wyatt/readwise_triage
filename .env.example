# Copy to .env and fill in your token
READWISE_TOKEN=your_token_here

# Scoring config (all optional - these are the defaults)
SCORING_WINDOW_DAYS=14
MAX_ITEMS_PER_BUCKET=15
SCORE_CURVE=sqrt                # sqrt | log | linear
ENABLE_READ_HISTORY=false
READ_HISTORY_WEIGHT=0.5
ENABLE_LENGTH_SIGNAL=false
LENGTH_SIGNAL_WEIGHT=0.2
JUST_IN_DAYS=14
LONG_READ_MIN_WORDS=2500
SHORT_BLOG_MAX_WORDS=1200
PROMOTE_TAG=triage
DRY_RUN=true                    # Set to false to actually promote selected items
OUTPUT_JSON_PATH=output/readwise-triage.json
READWISE_MAX_REQUESTS_PER_MIN=240 # Throughput cap (Readwise allows up to 240/min)
