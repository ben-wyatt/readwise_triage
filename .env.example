# Share API secrets — set these via `wrangler secret put <NAME>` for production
# For local dev, copy to .dev.vars (gitignored)

SHARE_API_TOKEN=       # Bearer token for iPhone Shortcut auth
READWISE_TOKEN=        # Readwise Reader API token
OPENROUTER_API_KEY=    # OpenRouter API key for LLM summaries
GITHUB_TOKEN=          # GitHub personal access token (for Obsidian vault push)
